{
  "workbench.colorTheme": "Cobalt2",
  "workbench.editor.tabSizing": "shrink",
  "workbench.fontAliasing": "antialiased",
  "files.trimTrailingWhitespace": true,
  // this isn't really underline-thin but we hack it to be a thicker cursor
  "vscode_custom_css.imports": [
    "https://raw.githubusercontent.com/wesbos/cobalt2-vscode/master/cobalt2-custom-hacks.css",
    "/Users/apple/vscodestyles.css"
  ],
  "editor.cursorStyle": "underline-thin",
  "editor.cursorBlinking": "solid",
  "editor.renderWhitespace": "all",
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.stablePeek": true,
  "editor.fontFamily": "Operator Mono, Menlo, Monaco, 'Courier New', monospace",
  "editor.fontSize": 29,
  "editor.lineHeight": 40,
  "editor.letterSpacing": 0.5,
  "editor.fontWeight": "400",
  "editor.snippetSuggestions": "top",
  // this isn't really underline but we hack it to be a thicker cursor
  "editor.wordWrap": "on",
  "editor.colorDecorators": false,
  "editor.minimap.enabled": false,
  "editor.rulers": [
    80,
    100,
    120
  ],
  "editor.minimap.showSlider": "always",
  "extensions.ignoreRecommendations": false,
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    "**/.next": true
  },
  "emmet.syntaxProfiles": {
    "javascript": "html",
    "xml": {
      "attr_quotes": "single"
    }
  },
  "emmet.includeLanguages": {
    "javascript": "javascriptreact"
  },
  "javascript.implicitProjectConfig.experimentalDecorators": true,
  "window.zoomLevel": -1,
  "window.title": "${dirty} ${activeEditorMedium}${separator}${rootName}",
  "terminal.integrated.fontFamily": "Meslo LG M DZ for Powerline",
  "eslint.enable": true,
  "editor.formatOnSave": true,
  "[javascript]": {
    "editor.formatOnSave": false
  },
  "eslint.autoFixOnSave": true,
  "eslint.alwaysShowStatus": true,
  "discord.enabled": true
}